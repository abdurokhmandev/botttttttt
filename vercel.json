{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://botttttttt-production.up.railway.app/api/:path*"
    },
    {
      "source": "/marketing-admin",
      "destination": "https://botttttttt-production.up.railway.app/marketing-admin"
    },
    {
      "source": "/marketing-admin.html",
      "destination": "https://botttttttt-production.up.railway.app/marketing-admin"
    },
    {
      "source": "/go",
      "destination": "https://botttttttt-production.up.railway.app/go"
    },
    {
      "source": "/cefrchi-admin",
      "destination": "https://web-production-69ee71.up.railway.app/cefrchi-admin"
    },
    {
      "source": "/cefrchi_login",
      "destination": "https://web-production-69ee71.up.railway.app/cefrchi_login"
    },
    {
      "source": "/cefrchi-admin/:path*",
      "destination": "https://web-production-69ee71.up.railway.app/cefrchi-admin/:path*"
    },
    {
      "source": "/webappregister",
      "destination": "/marketing.html"
    },
    {
      "source": "/",
      "destination": "/portfolio.html"
    }
  ]
}
